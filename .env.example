# Supabase Configuration
# Dejar vacío hasta configurar el nuevo proyecto (el legacy aoyafhjpgmxcygqnklvl queda bloqueado en código)
# SUPABASE_DB_PASSWORD=your-database-password
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
# VITE_SUPABASE_URL=https://your-new-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Insforge API Configuration
# Used for data synchronization and products database
VITE_INSFORGE_URL=https://your-insforge-url
VITE_INSFORGE_API_KEY=your-insforge-api-key

# AI Agents Configuration
# Keys for ChatGPT / AI Assistant features
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_GROQ_API_KEY=your-groq-api-key

# Email Server (Gmail SMTP via Nodemailer)
# Used for subscription confirmation and order email alerts
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Aviso de nuevo pedido al admin (generar etiqueta Nacex)
ADMIN_ORDER_EMAIL=infobenalumox@gmail.com
SITE_URL=https://www.asfaltoygas.es

# Google Search Console (verificación por meta tag en la home)
# VITE_GOOGLE_SITE_VERIFICATION=tu-codigo-de-google

# Redsys Payment Gateway (Spain)
# Used for card/Bizum payment processing
VITE_REDSYS_SECRET_KEY=your-redsys-sha256-secret-key
VITE_REDSYS_COMMERCE_NUMBER=your-merchant-fuc-number
VITE_REDSYS_TERMINAL_NUMBER=001

# Nacex Shipping Integration (Web Service WS — https://pda.nacex.com/nacex_ws)
